# Frontend-only Firebase reference
# This static project does NOT auto-load .env files in the browser.
# Use these values to fill public/firebase-config.js.

FIREBASE_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Optional notes for your own setup
APP_BASE_URL=http://127.0.0.1:5500/public/
DEFAULT_START_TABLES=5
