PORT=3000

# Firebase Admin credentials
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Optional alternative to the three vars above:
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase client config
FIREBASE_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Optional default owner created on server start
DEFAULT_CAFE_NAME=My Cafe
DEFAULT_CAFE_EMAIL=owner@mycafe.local
DEFAULT_CAFE_PASSWORD=admin123

# Existing PostgreSQL source database, used only for the migration script
DB_USER=postgres
DB_HOST=localhost
DB_NAME=cafe_menu
DB_PASSWORD=admin
DB_PORT=5432

# Used by `npm run migrate:firebase` when a PostgreSQL cafe email
# does not already exist in Firebase Auth.
FIREBASE_MIGRATION_PASSWORD=ChangeMe123!
