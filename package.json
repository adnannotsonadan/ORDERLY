{
  "name": "qr-cafe-menu",
  "version": "1.0.0",
  "description": "QR-based café menu ordering system for college project",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=.env.local --env-file-if-exists=.env backend/server.js",
    "dev": "nodemon --exec \"node --env-file-if-exists=.env.local --env-file-if-exists=.env\" backend/server.js",
    "init:firestore": "node --env-file-if-exists=.env.local --env-file-if-exists=.env backend/scripts/init-firestore.js",
    "migrate:firestore": "node --env-file-if-exists=.env.local --env-file-if-exists=.env backend/scripts/migrate-firestore-schema.js",
    "import:menu": "node --env-file-if-exists=.env.local --env-file-if-exists=.env backend/scripts/import-menu.js"
  },
  "keywords": [
    "qr",
    "cafe",
    "menu",
    "ordering"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "nodemon": "^3.1.14",
    "qrcode": "^1.5.3"
  }
}
